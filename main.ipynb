   "source": [
    "### 3. Feature Engineering"
   ]
  },
  {
   "cell_type": "raw",
   "id": "deab5285",
   "metadata": {},
   "source": [
    "Based on the EDA, the graph is highly sparse but connected (power-law distribution/scale free). \n",
    "Therefore graph topology features (Adamic Adar, Jaccard, Preferential Attachment) will be very discriminative.\n",
    "Also, since node features are 99.4% zeros, we'll use fast sparse computations for text features (Cosine, Dot product, etc.)."
   ]
  },
  {
   "cell_type": "raw",
   "id": "52e7643c",
   "metadata": {
    "collapsed": true,
    "jupyter": {
     "outputs_hidden": true
    }
   },
   "source": [
    "import scipy.sparse as sp\n",
    "from sklearn.metrics.pairwise import cosine_similarity, paired_distances\n",
    "from tqdm import tqdm\n",
    "\n",
    "def build_features(edges, G, feature_matrix):\n",
    "        n_edges = len(edges)\n",
    "        features = np.zeros((n_edges, 10))\n",
    "        sparse_features = sp.csr_matrix(feature_matrix)\n",
    "        node_id_to_idx = {int(nid): i for i, nid in enumerate(node_ids)}\n",
    "        sources = [node_id_to_idx[int(e[0])] for e in edges]\n",
    "        targets = [node_id_to_idx[int(e[1])] for e in edges]\n",
    "        f_sources = sparse_features[sources]\n",
    "        f_targets = sparse_features[targets]\n",
    "        cos_sim = np.array(np.sum(f_sources.multiply(f_targets), axis=1)).flatten() / (\n",
    "            np.linalg.norm(f_sources.toarray(), axis=1) * np.linalg.norm(f_targets.toarray(), axis=1) + 1e-10\n",
    "        )\n",
    "        dot_prod = np.array(np.sum(f_sources.multiply(f_targets), axis=1)).flatten()\n",
    "        l2_dist = np.linalg.norm(f_sources.toarray() - f_targets.toarray(), axis=1)\n",
    "        jaccard, adamic_adar, pref_attach, common_neighbors, shortest_path = [], [], [], [], []\n",
    "        for u, v in tqdm(edges, desc=\"Computing Graph Features\"):\n",
    "                    try:\n",
    "                                    preds = nx.jaccard_coefficient(G, [(u, v)])\n",
    "                                    jaccard.append(next(preds)[2])\n",
    "except (ZeroDivisionError, nx.NetworkXError):\n",
    "            jaccard.append(0)\n",
    "        try:\n",
    "                        preds = nx.adamic_adar_index(G, [(u, v)])\n",
    "                        adamic_adar.append(next(preds)[2])\n",
    "except (ZeroDivisionError, nx.NetworkXError):\n",
    "                adamic_adar.append(0)\n",
    "            preds = nx.preferential_attachment(G, [(u, v)])\n",
    "        pref_attach.append(next(preds)[2])\n",
    "        common_neighbors.append(len(list(nx.common_neighbors(G, u, v))))\n",
    "        try:\n",
    "                        path_len = nx.shortest_path_length(G, u, v)\n",
    "                        shortest_path.append(min(path_len, 5))\n",
    "except (nx.NetworkXNoPath, nx.NodeNotFound):\n",
    "                shortest_path.append(-1)\n",
    "        features[:, 0], features[:, 1], features[:, 2] = cos_sim, dot_prod, l2_dist\n",
    "    features[:, 3], features[:, 4], features[:, 5] = jaccard, adamic_adar, pref_attach\n",
    "    features[:, 6], features[:, 7] = common_neighbors, shortest_path\n",
    "    clustering = nx.clustering(G)\n",
    "    features[:, 8] = [clustering[u] + clustering[v] for u, v in edges]\n",
    "    features[:, 9] = [abs(clustering[u] - clustering[v]) for u, v in edges]\n",
    "    return features\n"
   ]
  },
